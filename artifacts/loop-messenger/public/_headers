# Cloudflare Pages — caching + security headers for Loop Messenger

# Service worker — never cache
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate
  Service-Worker-Allowed: /

# Hashed assets — 1 year immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
  Vary: Accept-Encoding

# Manifest + icons — short cache
/manifest.json
  Cache-Control: public, max-age=3600, must-revalidate
/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate
/opengraph.jpg
  Cache-Control: public, max-age=86400, must-revalidate
/robots.txt
  Cache-Control: public, max-age=86400

# HTML shell — always fresh
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' https: blob:; connect-src 'self' https://api.ng.termii.com https://messenger.rald.cloud https://chat.rald.cloud wss://messenger.rald.cloud wss://chat.rald.cloud https://*.supabase.co wss://*.supabase.co wss://*.livekit.cloud https://*.livekit.cloud https://*.replit.dev https://*.replit.app https://*.pages.dev; worker-src 'self' blob:

