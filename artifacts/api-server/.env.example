# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname
SESSION_SECRET=change-me-in-production-min-32-chars

# ── SMS OTP (Termii) ──────────────────────────────────────────────────────────
TERMII_API_KEY=
TERMII_SENDER_ID=N-Alert

# ── RALD SSO Bridge (Phase 1) ─────────────────────────────────────────────────
# Shared HS256 secret with rald-auth-core (auth.rald.cloud).
# Must match RALD_JWT_SECRET on the rald-auth worker.
# Enables POST /api/auth/rald-sso and POST /api/auth/rald-sso/link.
# Obtain from: GitHub org secrets → RALD_JWT_SECRET
RALD_JWT_SECRET=

# ── Web Push (optional) ───────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:platform@rald.cloud

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
